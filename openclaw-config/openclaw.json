{
  "agents": {
    "defaults": {
      "workspace": "/Users/recoupable/.openclaw/workspace",
      "models": {
        "vercel-ai-gateway/anthropic/claude-opus-4.6": {
          "alias": "Vercel AI Gateway"
        }
      },
      "model": {
        "primary": "vercel-ai-gateway/anthropic/claude-opus-4.6"
      },
      "subagents": {
        "allowAgents": [
          "main"
        ],
        "maxConcurrent": 5,
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": true
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "messages": {
    "ackReaction": "eyes",
    "ackReactionScope": "all",
    "removeAckAfterReply": true,
    "statusReactions": {
      "enabled": true
    }
  },
  "tools": {
    "profile": "coding"
  },
  "auth": {
    "profiles": {
      "vercel-ai-gateway:default": {
        "provider": "vercel-ai-gateway",
        "mode": "api_key"
      }
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "groupPolicy": "open",
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "channels": {
        "#cosmo-chat": {
          "requireMention": false,
          "enabled": true
        },
        "#cosmo-content": {
          "requireMention": false,
          "enabled": true
        }
      },
      "replyToModeByChatType": {
        "channel": "all",
        "group": "all"
      },
      "capabilities": {
        "interactiveReplies": true
      }
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": true
        },
        "bootstrap-extra-files": {
          "enabled": true
        },
        "command-logger": {
          "enabled": true
        },
        "session-memory": {
          "enabled": true
        }
      }
    }
  },
  "wizard": {
    "lastRunAt": "2026-04-12T01:02:07.620Z",
    "lastRunVersion": "2026.4.9",
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "meta": {
    "lastTouchedVersion": "2026.4.9",
    "lastTouchedAt": "2026-04-12T23:33:35.743Z"
  },
  "plugins": {
    "entries": {
      "vercel-ai-gateway": {
        "enabled": true
      }
    }
  },
  "mcp": {
    "servers": {
      "parallel-search": {
        "url": "https://search-mcp.parallel.ai/mcp",
        "headers": {
          "Authorization": "${MCP_PARALLEL_SEARCH_AUTH}"
        }
      }
    }
  }
}